        renderStage();
    }

    function playSound(type) {
        const s = sounds[type].cloneNode();
        s.volume = document.getElementById('volSlider').value;
        s.play();
    }

    function updateVolume(val) { sounds.bgm.volume = val; }

    function handleTap(el, src) {
